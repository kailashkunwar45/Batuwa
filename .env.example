# ──────────────────────────────────────────────────────────────
# BATUWA PLATFORM - GLOBAL ENVIRONMENT VARIABLES
# Copy this to .env and fill in your production secrets.
# ──────────────────────────────────────────────────────────────

# ─── DATABASE (PostgreSQL) ───────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/batuwa_db?schema=public"

# ─── REDIS (Caching & Idempotency) ───────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── SECURITY ────────────────────────────────────────────────
JWT_ACCESS_SECRET="generate_a_long_random_string_here"
JWT_REFRESH_SECRET="generate_another_long_random_string_here"
ENCRYPTION_KEY="32_character_string_for_data_encryption"

# ─── NCHL (ConnectIPS) ───────────────────────────────────────
NCHL_BASE_URL="https://uat.connectips.com:443/api"
NCHL_MERCHANT_ID="GET_FROM_NCHL"
NCHL_APP_ID="GET_FROM_NCHL"
NCHL_APP_NAME="BATUWA"
NCHL_API_SECRET="YOUR_NCHL_PRIVATE_SECRET"

# ─── THIRD PARTY (Production Only) ───────────────────────────
# Cloudinary (Image storage for KYC/Receipts)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Postmark/SendGrid (Emails)
EMAIL_SERVICE_API_KEY=""

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─── APP CONFIG ──────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
ALLOWED_ORIGINS="https://admin.batuwa.com,https://merchant.batuwa.com"

# ─── FINTECH LIMITS ──────────────────────────────────────────
KYC_L0_DAILY_LIMIT=1000
KYC_L1_DAILY_LIMIT=50000
KYC_L2_DAILY_LIMIT=500000
FRAUD_AUTO_FREEZE_SCORE=0.85
