{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "types": ["jest", "node"],
    "outDir": "./dist",

    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@auth/*": ["src/auth/*"],
      "@wallet/*": ["src/wallet/*"],
      "@payments/*": ["src/payments/*"],
      "@users/*": ["src/users/*"],
      "@kyc/*": ["src/kyc/*"],
      "@admin/*": ["src/admin/*"],
      "@fraud/*": ["src/fraud/*"],
      "@notifications/*": ["src/notifications/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@jobs/*": ["src/jobs/*"],
      "@events/*": ["src/events/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
